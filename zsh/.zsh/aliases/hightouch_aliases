# Hightouch aliases

# claude code — always include ht-vault as a workspace dir (for @ file mentions)
alias claude='claude --add-dir ~/Documents/ht-vault'

alias replica="psql -h production-htdb-replica -U readonly -d htdb --set=PROMPT1='%[%033[33m%][replica] %/%R%#%[%033[0m%]'"
alias localdb="psql -h localhost -p 5432 -U htu -d htdb --set=PROMPT1='%[%033[32m%][localhost] %/%R%#%[%033[0m%]'"
alias local_agents_db="PGPASSWORD=this_password_is_only_used_in_dev PGOPTIONS='-c search_path=ad_artifacts,hightouch_content,competitor_ads,public' psql -h localhost -p 5435 -U agents -d agents --set=PROMPT1='%[%033[32m%][localhost] %/%R%#%[%033[0m%]'"
alias prod_agents="psql -h production-agents -p 5432 -U master agents --set=PROMPT1='%[%033[1;31m%][!!! PROD (Agents)] %/%R%#%[%033[0m%]'"


dbs() {
  # Requires fzf to be installed
  # Grab all aliases
  local aliases
  # Only keep ones that match your DB naming patterns
  aliases=$(alias | awk -F'[ =]' '
    /psql -h/ {
      gsub(/alias /, "", $1)
      print $1
    }')

  # Use fzf to select one
  local choice
  choice=$(printf '%s\n' "$aliases" | fzf --height 10 --border --prompt="Select DB: ")

  # If a choice was made, run it
  if [[ -n "$choice" ]]; then
    eval "$choice"
  fi
}
